generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Article {
  id              Int      @id @default(autoincrement())
  title           String
  authors         String
  pageRange       String
  publicationDate DateTime
  pdfPath         String
  extraFilePath   String?
  views           Int      @default(0)
  keywords        String   
  categoryId      Int
  category        Category @relation(fields: [categoryId], references: [id])
  createdAt       DateTime @default(now())
  reviews         Review[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  code     String    @unique
  articles Article[]
}

model Reviewer {
  id          Int      @id @default(autoincrement())
  name        String   @unique 
  affiliation String
  field       String
  createdAt   DateTime @default(now())
  reviews Review[]
}

model Admin {
  id       Int    @id @default(autoincrement())
  login    String @unique
  password String
}

model Editor {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  affiliation String
  role        String   
  createdAt   DateTime @default(now())
}

model Review {
  id          Int      @id @default(autoincrement())
  content     String   
  rating      Int      @default(5) // Ocena 1-5
  status      String   @default("Accepted") 
  createdAt   DateTime @default(now())

  articleId   Int
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  reviewerId  Int
  reviewer    Reviewer @relation(fields: [reviewerId], references: [id])
}